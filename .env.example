# MySQL
MYSQL_ROOT_PASSWORD=rootpw
MYSQL_DATABASE=inventory
MYSQL_USER=app_user
MYSQL_PASSWORD=app_pw

# Debezium connector account
DEBEZIUM_DB_USER=debezium_user
DEBEZIUM_DB_PASSWORD=debezium_pw

# Kafka / Connect
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
CONNECT_REST_URL=http://connect:8083
TOPIC_PREFIX=dbserver1
TABLE_INCLUDE_LIST=inventory.customers,inventory.orders,inventory.products

# Processor
PROCESSOR_GROUP_ID=cdc-processor-group
PROCESSOR_BATCH_SIZE=1000
PROCESSOR_FLUSH_RECORDS=5000
PROCESSOR_FLUSH_SECONDS=20
DATA_LAKE_ROOT=/app/data_lake
STATE_DB_PATH=/app/state/schemas.db
LINEAGE_OUTPUT_PATH=/app/output/lineage_report.json
AUTO_REGISTER_CONNECTOR=true
